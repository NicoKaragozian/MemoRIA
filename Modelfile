FROM /models/memoria.gguf

# Chat template de Gemma. El user prompt completo (header del chat +
# contexto + marcador "[Tu próximo mensaje:]") viene armado por el backend
# desde scripts.build_dataset._format_user_prompt — el modelo solo tiene que
# completar la respuesta del usuario.
TEMPLATE """<start_of_turn>user
{{ .Prompt }}<end_of_turn>
<start_of_turn>model
"""

# Sin SYSTEM prompt: en el flujo conversacional toda la información de
# contexto (chat, participantes, mensajes previos) ya está en el user prompt.
# Un system prompt acá solo agregaría sesgo en runtime.

PARAMETER temperature 0.8
PARAMETER top_p 0.9
PARAMETER repeat_penalty 1.1
PARAMETER num_ctx 4096
PARAMETER stop "<end_of_turn>"
PARAMETER stop "<start_of_turn>"
